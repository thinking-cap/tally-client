{
  "compilerOptions": {
    "target":            "ES2020",
    "module":            "CommonJS",
    "moduleResolution":  "Node",
    "outDir":            "dist",
    "declaration":       true,
    "declarationMap":    true,
    "sourceMap":         true,
    "strict":            true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "lib":               ["ES2020"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
